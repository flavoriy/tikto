{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./apps/web/src/*"
      ],
      "@shared/*": [
        "./packages/shared/src/*"
      ],
      "@contracts/*": [
        "./packages/contracts/src/*"
      ],
      "@prisma/client": [
        "./node_modules/.prisma/client"
      ]
    }
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "packages/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist-services",
    "apps/web/.next"
  ]
}
