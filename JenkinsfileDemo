pipeline {
    agent {
        label 'agent'
    }

    environment {
        CI = 'true'
        NEXT_TELEMETRY_DISABLED = '1'
        REGISTRY = 'ghcr.io'
        IMAGE_REPOSITORY = 'ghcr.io/Flavoriy/tikto'
        DOCKERFILE = 'Dockerfile'
        
        // Đổi thành MY_DOCKER_CONTEXT để không bị trùng với biến môi trường hệ thống của Jenkins
        MY_DOCKER_CONTEXT = '.' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Clean Install & Build') {
            agent {
                docker {
                    image 'node:20-alpine'
                    // Thay đổi đường dẫn mount sang thư mục .npm-cache ngay tại workspace
                    args '-v ${WORKSPACE}/.npm-cache:/.npm --env npm_config_cache=/.npm'
                    reuseNode true
                }
            }
            steps {
                echo 'Running Node.js build inside node:20-alpine container...'
                sh 'node -v'
                sh 'npm -v'
                sh 'npm ci'
                sh 'npm run build'
            }
        }

        stage('Prepare Image Tag') {
            steps {
                script {
                    String branchName = env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'local'
                    String commit = env.GIT_COMMIT ?: sh(script: 'git rev-parse --short=12 HEAD', returnStdout: true).trim()
                    String rawTag = "${branchName}-${commit.take(12)}-${env.BUILD_NUMBER ?: '0'}"

                    env.IMAGE_TAG = rawTag
                        .replaceFirst(/^origin\//, '')
                        .replaceAll(/[^A-Za-z0-9_.-]/, '-')
                        .take(128)
                    env.IMAGE_REF = "${env.IMAGE_REPOSITORY}:${env.IMAGE_TAG}"

                    echo "Docker image: ${env.IMAGE_REF}"
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo 'Building Docker image on Jenkins agent...'
                sh '''
                    set -e
                    # Sử dụng biến MY_DOCKER_CONTEXT đã được đổi tên ở đây
                    docker build -f "$DOCKERFILE" -t "$IMAGE_REF" "$MY_DOCKER_CONTEXT"
                '''
            }
        }

        stage('Docker Push GHCR') {
            steps {
                echo 'Pushing Docker image to GHCR...'
                withCredentials([usernamePassword(credentialsId: 'ghcr-token', usernameVariable: 'REGISTRY_USERNAME', passwordVariable: 'REGISTRY_TOKEN')]) {
                    sh '''
                        set -e
                        set +x
                        echo "$REGISTRY_TOKEN" | docker login "$REGISTRY" -u "$REGISTRY_USERNAME" --password-stdin
                        set -x
                        docker push "$IMAGE_REF"
                        docker logout "$REGISTRY"
                    '''
                }
            }
        }
    }
}