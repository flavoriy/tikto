pipeline {
    agent {
        label 'agent'
    }

    options {
        skipDefaultCheckout(true)
    }

    environment {
        CI = 'true'
        NEXT_TELEMETRY_DISABLED = '1'
        REGISTRY = 'ghcr.io'
        IMAGE_REPOSITORY = 'ghcr.io/flavoriy/tikto'
        IMAGE_VERSION_PREFIX = '1.0'
        IMAGE_EXTRA_TAG = 'latest'
        DOCKERFILE = 'Dockerfile'
        MY_DOCKER_CONTEXT = '.' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Image Tag') {
            steps {
                script {
                    String buildNumber = env.BUILD_NUMBER ?: '0'

                    env.IMAGE_TAG = "${env.IMAGE_VERSION_PREFIX}.${buildNumber}"
                    env.IMAGE_REF = "${env.IMAGE_REPOSITORY}:${env.IMAGE_TAG}"
                    env.IMAGE_EXTRA_REF = "${env.IMAGE_REPOSITORY}:${env.IMAGE_EXTRA_TAG}"

                    echo "Docker image target ref: ${env.IMAGE_REF}"
                    echo "Docker image extra ref: ${env.IMAGE_EXTRA_REF}"
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo 'Building Docker image on Jenkins agent...'
                withCredentials([file(credentialsId: 'tikto', variable: 'SECRET_ENV')]) {
                    sh '''
                        set -e
                        set +x
                        
                        if ! command -v docker >/dev/null 2>&1; then
                          echo "Docker is not installed or not available in PATH on this Jenkins agent." >&2
                          exit 127
                        fi

                        set -a
                        . "$SECRET_ENV"
                        set +a
                        
                        docker build \
                          --build-arg DATABASE_URL="$DATABASE_URL" \
                          -f "$DOCKERFILE" \
                          -t "$IMAGE_REF" \
                          -t "$IMAGE_EXTRA_REF" \
                          "$MY_DOCKER_CONTEXT"
                    '''
                }
            }
        }

        stage('Docker Push GHCR') {
            steps {
                echo 'Pushing Docker image to GHCR...'
                // Sửa đổi từ loại 'usernamePassword' sang 'string' để nhận diện đúng loại Secret text 'ghcr-token'
                withCredentials([string(credentialsId: 'ghcr-token', variable: 'REGISTRY_TOKEN')]) {
                    sh '''
                        set -e
                        set +x
                        # Hệ thống sử dụng trực tiếp token kết hợp với tên tài khoản của bạn để login
                        echo "$REGISTRY_TOKEN" | docker login "$REGISTRY" -u "flavoriy" --password-stdin
                        set -x
                        
                        docker push "$IMAGE_REF"
                        docker push "$IMAGE_EXTRA_REF"
                        docker logout "$REGISTRY"
                    '''
                }
            }
        }
    }
}
