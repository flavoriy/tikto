NEXT_PUBLIC_APP_URL=http://localhost:3000

TIKTO_PROFILE_API_URL=http://localhost:4100
TIKTO_TASKS_API_URL=http://localhost:4200
TIKTO_CALENDAR_API_URL=http://localhost:4300
TIKTO_DASHBOARD_API_URL=http://localhost:4400
# Optional. Set this in production so only the Next.js proxy can call internal services.
TIKTO_INTERNAL_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older Supabase projects may call this anon key. The app accepts either this
# value or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@YOUR_REGION.pooler.supabase.com:5432/postgres
# Optional per-service database overrides. Leave empty for local development to fall back to DATABASE_URL.
PROFILE_DATABASE_URL=
TASKS_DATABASE_URL=
CALENDAR_DATABASE_URL=
# Percent-encode special characters in the password section of the URL.
# Example: @ -> %40, # -> %23
